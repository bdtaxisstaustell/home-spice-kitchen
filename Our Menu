<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Menu - Home Spice Catering</title>

<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background-color: #f8f5f0;
}

/* NAVBAR */
.navbar {
    background-color: #c0392b;
    padding: 15px 30px;
    display: flex;
    justify-content: space-between;
    color: white;
}

.nav-links a {
    color: white;
    text-decoration: none;
    margin-left: 20px;
    font-weight: bold;
}

/* MENU */
.menu {
    padding: 60px 20px;
    text-align: center;
}

.menu h1 {
    color: #c0392b;
}

.menu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    max-width: 1000px;
    margin: auto;
}

.card {
    background: white;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
}

.price {
    color: #c0392b;
    font-weight: bold;
}

/* FOOTER */
.footer {
    background: #222;
    color: #aaa;
    text-align: center;
    padding: 20px;
}
</style>
</head>

<body>

<!-- NAVBAR -->
<div class="navbar">
    <h2>Home Spice Catering</h2>
    <div class="nav-links">
        <a href="index.html">Home</a>
    </div>
</div>

<!-- MENU -->
<div class="menu">
    <h1>Our Menu</h1>

    <div class="menu-grid">

        <div class="card">
            <h3>Chicken Biryani</h3>
            <p>Fragrant rice with spiced chicken</p>
            <p class="price">£8.99</p>
        </div>

        <div class="card">
            <h3>Akhni (Yakhni Pulao)</h3>
            <p>Light, aromatic rice dish cooked with meat broth</p>
            <p class="price">£9.49</p>
        </div>

        <div class="card">
            <h3>Chicken Curry</h3>
            <p>Traditional homemade curry</p>
            <p class="price">£8.99</p>
        </div>

        <div class="card">
            <h3>Beef Bhuna</h3>
            <p>Rich, slow-cooked beef dish</p>
            <p class="price">£9.99</p>
        </div>

        <div class="card">
            <h3>Daal</h3>
            <p>Comforting lentils cooked at home style</p>
            <p class="price">£6.99</p>
        </div>

    </div>
</div>

<!-- FOOTER -->
<div class="footer">
    <p>Powered by Trina’s Cloud Kitchen</p>
</div>

</body>
</html>
